generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // ↑ plus de "url" ici, c'est dans prisma.config.ts maintenant
}

// === Modèles ===

model User {
  id            String   @id @default(cuid())
  authentikId   String?  @unique
  email         String   @unique
  username      String   @unique
  displayName   String
  color         String   @default("#3b82f6")
  emailVerified DateTime?
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  slots          Slot[]
  recurringRules RecurringRule[]
  accounts       Account[]
  sessions       Session[]
}

enum SlotStatus {
  AVAILABLE
  WORKING
  UNAVAILABLE
  CUSTOM
}

enum TimeSlot {
  MORNING
  AFTERNOON
  EVENING
}

model Slot {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime   @db.Date
  timeSlot     TimeSlot
  status       SlotStatus
  customLabel  String?
  customColor  String?
  note         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, date, timeSlot])
  @@index([date])
}

model RecurringRule {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ruleSetId       String?
  ruleSetName     String?
  dayOfWeek       Int
  timeSlot        TimeSlot
  status          SlotStatus
  customLabel     String?
  customColor     String?
  startDate       DateTime   @db.Date
  endDate         DateTime?  @db.Date
  rhythm          Int        @default(1)
  rhythmWeekStart DateTime?  @db.Date
  priority        Int        @default(0) // priorité plus haute = écrase les règles en dessous
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([userId, ruleSetId])
  @@index([userId, dayOfWeek, timeSlot])
  @@index([userId, priority])
}

// === Tables Auth.js ===

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}